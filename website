<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Equilíbrio Real — O guia para emagrecer sem dietas malucas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,500&family=Work+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#16241C;
    --forest:#1E3329;
    --forest-deep:#142420;
    --ivory:#FAF6ED;
    --ivory-dim:#F1ECDF;
    --gold:#C79A2E;
    --gold-dim:#A57E1F;
    --clay:#C97B62;
    --line: rgba(22,36,28,0.12);
    --line-light: rgba(250,246,237,0.16);
    --max: 1120px;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    font-family:'Work Sans', sans-serif;
    color:var(--ink);
    background:var(--ivory);
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    *{animation-duration:0.001ms !important; transition-duration:0.001ms !important;}
  }
  img,svg{display:block; max-width:100%;}
  a{color:inherit; text-decoration:none;}
  .wrap{max-width:var(--max); margin:0 auto; padding:0 28px;}
  .eyebrow{
    font-family:'Space Mono', monospace;
    font-size:12.5px;
    letter-spacing:0.14em;
    text-transform:uppercase;
    font-weight:700;
  }
  h1,h2,h3{
    font-family:'Fraunces', serif;
    font-weight:600;
    letter-spacing:-0.01em;
    line-height:1.12;
  }
  h2{font-size:clamp(28px,4vw,42px); margin-bottom:18px;}
  h3{font-size:22px; margin-bottom:10px;}
  p{font-size:17px;}
  .btn{
    display:inline-flex; align-items:center; gap:10px;
    font-family:'Work Sans', sans-serif;
    font-weight:600; font-size:16px;
    padding:16px 30px;
    border-radius:100px;
    cursor:pointer;
    border:none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .btn:focus-visible{outline:3px solid var(--gold); outline-offset:3px;}
  .btn-gold{ background:var(--gold); color:var(--forest-deep); box-shadow:0 8px 24px rgba(199,154,46,0.35); }
  .btn-gold:hover{ transform:translateY(-2px); box-shadow:0 12px 30px rgba(199,154,46,0.45); }
  .btn-outline{ background:transparent; color:var(--ivory); border:1.5px solid var(--line-light); }
  .btn-outline:hover{ background:rgba(250,246,237,0.08); }

  /* ---------- NAV ---------- */
  nav{
    position:sticky; top:0; z-index:50;
    background:rgba(20,36,32,0.92);
    backdrop-filter:blur(8px);
    border-bottom:1px solid var(--line-light);
  }
  nav .wrap{ display:flex; align-items:center; justify-content:space-between; height:72px; }
  .logo{ font-family:'Fraunces', serif; font-weight:600; font-size:20px; color:var(--ivory); }
  .logo span{ color:var(--gold); font-style:italic; }
  nav .btn{ padding:10px 22px; font-size:14px; }

  /* ---------- HERO ---------- */
  .hero{
    background: radial-gradient(120% 100% at 80% 0%, #25422F 0%, var(--forest) 45%, var(--forest-deep) 100%);
    color:var(--ivory);
    padding:88px 0 0;
    overflow:hidden;
    position:relative;
  }
  .hero .wrap{ position:relative; }
  .hero-grid{
    display:grid; grid-template-columns: 1.1fr 0.9fr; gap:40px; align-items:center;
    padding-bottom:90px;
  }
  .hero .eyebrow{ color:var(--gold); margin-bottom:22px; display:block; }
  .hero h1{ font-size:clamp(34px,5.2vw,58px); margin-bottom:22px; max-width:640px; }
  .hero h1 em{ font-style:italic; color:var(--gold); }
  .hero p.lead{ font-size:19px; color:rgba(250,246,237,0.82); max-width:480px; margin-bottom:34px; }
  .hero-ctas{ display:flex; gap:14px; flex-wrap:wrap; align-items:center; margin-bottom:14px; }
  .hero-note{ font-size:13.5px; color:rgba(250,246,237,0.55); }

  /* plate signature graphic */
  .plate-wrap{ display:flex; justify-content:center; }
  .plate{ width:min(380px, 90%); aspect-ratio:1/1; position:relative; }
  .plate svg{ width:100%; height:100%; }
  .plate-label{
    position:absolute; font-family:'Space Mono', monospace; font-size:11px;
    letter-spacing:0.06em; color:rgba(250,246,237,0.75);
  }

  .hero-divider{ height:90px; }
  .arc-divider{ display:block; width:100%; height:64px; }

  /* ---------- SECTION GENERIC ---------- */
  section{ padding:90px 0; }
  .section-ivory{ background:var(--ivory); }
  .section-dim{ background:var(--ivory-dim); }
  .section-forest{ background:var(--forest-deep); color:var(--ivory); }
  .center{ text-align:center; }
  .kicker{ color:var(--gold-dim); display:block; margin-bottom:14px; }
  .section-forest .kicker{ color:var(--gold); }
  .lede{ max-width:620px; font-size:18px; color:#3C4A40; }
  .section-forest .lede{ color:rgba(250,246,237,0.78); }

  .reveal{ opacity:0; transform:translateY(22px); transition:opacity 0.7s ease, transform 0.7s ease; }
  .reveal.in{ opacity:1; transform:translateY(0); }

  /* ---------- CYCLE ---------- */
  .cycle{ display:grid; grid-template-columns:repeat(5,1fr); gap:18px; margin-top:50px; }
  .cycle-step{
    background:#fff; border:1px solid var(--line); border-radius:14px; padding:24px 18px;
    position:relative;
  }
  .cycle-step .num{ font-family:'Space Mono',monospace; font-size:12px; color:var(--clay); margin-bottom:10px; display:block; }
  .cycle-step p{ font-size:14.5px; color:#3C4A40; }
  .cycle-arrow{ display:none; }
  @media (max-width:880px){
    .cycle{ grid-template-columns:1fr; }
  }

  /* ---------- PILLARS ---------- */
  .pillars{ display:grid; grid-template-columns:repeat(4,1fr); gap:22px; margin-top:54px; }
  .pillar{
    background:rgba(250,246,237,0.05); border:1px solid var(--line-light); border-radius:16px;
    padding:30px 26px;
  }
  .pillar-icon{ width:38px; height:38px; margin-bottom:18px; }
  .pillar h3{ color:var(--ivory); font-size:19px; }
  .pillar p{ font-size:15px; color:rgba(250,246,237,0.72); }
  @media (max-width:980px){ .pillars{ grid-template-columns:1fr 1fr; } }
  @media (max-width:600px){ .pillars{ grid-template-columns:1fr; } }

  /* ---------- TOC ---------- */
  .toc-grid{ display:grid; grid-template-columns:1fr 1fr; gap:0 60px; margin-top:50px; }
  .toc-item{
    display:flex; gap:18px; padding:20px 0; border-bottom:1px solid var(--line);
  }
  .toc-item .toc-num{
    font-family:'Fraunces', serif; font-style:italic; font-size:24px; color:var(--clay); flex-shrink:0; width:34px;
  }
  .toc-item h4{ font-family:'Work Sans', sans-serif; font-weight:600; font-size:16.5px; margin-bottom:4px; }
  .toc-item p{ font-size:14px; color:#5C6B5F; }
  @media (max-width:780px){ .toc-grid{ grid-template-columns:1fr; } }

  /* ---------- AUDIENCE ---------- */
  .audience{ display:grid; grid-template-columns:1fr 1fr; gap:28px; margin-top:50px; }
  .audience-card{ border-radius:18px; padding:34px; }
  .audience-yes{ background:#EEF1E6; border:1px solid #D7DEC7; }
  .audience-no{ background:#F7EEE9; border:1px solid #E8D2C6; }
  .audience-card h3{ font-size:19px; margin-bottom:18px; }
  .audience-card ul{ list-style:none; display:flex; flex-direction:column; gap:13px; }
  .audience-card li{ display:flex; gap:10px; font-size:15.5px; align-items:flex-start; }
  .audience-card li svg{ flex-shrink:0; margin-top:3px; }
  @media (max-width:780px){ .audience{ grid-template-columns:1fr; } }

  /* ---------- TESTIMONIALS ---------- */
  .testimonials{ display:grid; grid-template-columns:repeat(3,1fr); gap:22px; margin-top:50px; }
  .testimonial{
    background:#fff; border:1px solid var(--line); border-radius:16px; padding:28px;
    display:flex; flex-direction:column; gap:16px;
  }
  .testimonial .quote{ font-family:'Fraunces', serif; font-style:italic; font-size:16.5px; color:#2A362D; }
  .testimonial .who{ font-size:13.5px; color:#6B7A6E; font-family:'Space Mono', monospace; }
  .placeholder-flag{
    display:inline-block; font-family:'Space Mono', monospace; font-size:10.5px; letter-spacing:.05em;
    background:#FFF3D6; color:#8A6308; padding:3px 8px; border-radius:5px; margin-bottom:6px; width:fit-content;
  }
  @media (max-width:880px){ .testimonials{ grid-template-columns:1fr; } }

  /* ---------- FAQ ---------- */
  .faq{ max-width:760px; margin:50px auto 0; }
  .faq-item{ border-bottom:1px solid var(--line); }
  .faq-q{
    width:100%; text-align:left; background:none; border:none; padding:22px 0;
    display:flex; justify-content:space-between; align-items:center; gap:16px;
    font-family:'Work Sans', sans-serif; font-weight:600; font-size:16.5px; color:var(--ink); cursor:pointer;
  }
  .faq-q .plus{ font-size:22px; color:var(--clay); transition:transform 0.3s ease; flex-shrink:0; }
  .faq-item.open .plus{ transform:rotate(45deg); }
  .faq-a{ max-height:0; overflow:hidden; transition:max-height 0.35s ease; }
  .faq-a p{ font-size:15.5px; color:#4A584D; padding-bottom:22px; max-width:640px; }

  /* ---------- FINAL CTA ---------- */
  .final-cta{ text-align:center; padding:100px 0; }
  .price-card{
    max-width:460px; margin:46px auto 0; background:rgba(250,246,237,0.06);
    border:1px solid var(--line-light); border-radius:20px; padding:42px 36px;
  }
  .price-old{ text-decoration:line-through; color:rgba(250,246,237,0.45); font-size:16px; }
  .price-new{ font-family:'Fraunces', serif; font-size:46px; color:var(--gold); margin:6px 0 4px; }
  .price-card .btn{ width:100%; justify-content:center; margin-top:22px; }
  .guarantee{ display:flex; align-items:center; gap:10px; justify-content:center; margin-top:18px; font-size:13.5px; color:rgba(250,246,237,0.6); }

  /* ---------- FOOTER ---------- */
  footer{ background:var(--forest-deep); color:rgba(250,246,237,0.55); padding:46px 0 36px; font-size:13px; }
  footer .wrap{ display:flex; flex-direction:column; gap:18px; }
  footer .disclaimer{ max-width:760px; line-height:1.7; }
  footer .bottom-row{ display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px; border-top:1px solid var(--line-light); padding-top:20px; }

  @media (max-width:900px){
    .hero-grid{ grid-template-columns:1fr; }
    .plate-wrap{ order:-1; margin-bottom:10px; }
    .hero h1{ max-width:none; }
    .hero p.lead{ max-width:none; }
  }
</style>
</head>
<body>

<nav>
  <div class="wrap">
    <div class="logo">Equilíbrio <span>Real</span></div>
